# LLM providers
#
# GROQ — clause extraction (41 categories × N docs, ~2050 calls/job)
#   Fast free inference. Free tier: 6000 TPM.
#   Get a key at: https://console.groq.com
GROQ_API_KEY=your_groq_api_key_here

# OPENROUTER (optional, FREE TIER) — reasoning quality upgrade for small jobs (≤25 docs)
#   Free tier: ~200 req/day. Model names require `:free` suffix.
#   Leave blank to use Ollama for reasoning instead.
#   Get a key at: https://openrouter.ai
OPENROUTER_API_KEY=

# OLLAMA — local reasoning fallback (zero cost, zero rate limit)
#   Install: https://ollama.com  |  Pull model: ollama pull mistral-nemo
#   Used as the default reasoning model and final extraction fallback.
OLLAMA_BASE_URL=http://localhost:11434

# LLM model selection (optional overrides)
# LLM_REASONING_MODEL=ollama/mistral-nemo          # default — unlimited, local
# LLM_REASONING_MODEL=openrouter/nvidia/nemotron-3-super-120b-a12b:free  # small jobs only
# LLM_EXTRACTION_MODEL=groq/llama-3.1-8b-instant   # default

# Infrastructure (matches docker-compose.yml defaults)
QDRANT_HOST=localhost
QDRANT_PORT=6333
NEO4J_URI=bolt://localhost:7687
NEO4J_USER=neo4j
NEO4J_PASSWORD=password

# Application
LOG_LEVEL=INFO
ENVIRONMENT=development
