# LLM providers
#
# OPENAI — clause extraction primary (gpt-4o-mini)
#   Get a key at: https://platform.openai.com/api-keys
OPENAI_API_KEY=your_openai_api_key_here

# GROQ — extraction fallback when OpenAI is unavailable / rate-limited
#   Free tier: 6000 TPM. Get a key at: https://console.groq.com
GROQ_API_KEY=your_groq_api_key_here

# OPENROUTER (optional, FREE TIER) — reasoning quality upgrade for small jobs (≤25 docs)
#   Free tier: ~200 req/day. Model names require `:free` suffix.
#   Leave blank to use Ollama for reasoning instead.
#   Get a key at: https://openrouter.ai
OPENROUTER_API_KEY=

# OLLAMA — local reasoning fallback (zero cost, zero rate limit)
#   Install: https://ollama.com  |  Pull model: ollama pull mistral-nemo
#   Used as the default reasoning model and final extraction fallback.
OLLAMA_BASE_URL=http://localhost:11434

# LLM model selection (optional overrides)
# Default for both roles is gpt-4o-mini (Sprint 26 — all roles unified).
# Override to force offline/local operation:
# LLM_REASONING_MODEL=ollama/mistral-nemo    # offline fallback — no rate limit, lower quality
# LLM_EXTRACTION_MODEL=ollama/mistral-nemo   # offline fallback

# Infrastructure (matches docker-compose.yml defaults)
QDRANT_HOST=localhost
QDRANT_PORT=6333
NEO4J_URI=bolt://localhost:7687
NEO4J_USER=neo4j
NEO4J_PASSWORD=password

# Retrieval tuning (optional)
# Cross-encoder re-ranker applied after RRF fusion. Empty = disabled (default).
# Adds ~50–200ms per retrieval call on M4 MPS. Recommended: BAAI/bge-reranker-v2-m3
# To benchmark: python eval/cuad_eval.py --n 100 --enrich-queries --reranker BAAI/bge-reranker-v2-m3
# RERANKER_MODEL=BAAI/bge-reranker-v2-m3

# Application
LOG_LEVEL=INFO
ENVIRONMENT=development

# Observability — OpenTelemetry (optional)
#   Set OTEL_ENDPOINT to export spans to a collector (e.g. http://localhost:4318).
#   Leave blank to disable export (spans are created but dropped — zero overhead).
#   OTEL_ENDPOINT=http://localhost:4318
